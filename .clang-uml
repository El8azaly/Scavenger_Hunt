compilation_database_dir: build

add_compile_flags:
  - "-isysroot"
  - "/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk"
  - "-I/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/lib/clang/17/include"
diagrams:
  core:
    type: class

  core:
    type: class
    glob:
      - "/Users/omarsalem/CLionProjects/Scavenger_Hunt/core/*.cpp"

  engine:
    type: class
    glob:
      - "/Users/omarsalem/CLionProjects/Scavenger_Hunt/engine/*.cpp"

  entities:
    type: class
    glob:
      - "/Users/omarsalem/CLionProjects/Scavenger_Hunt/entities/*.cpp"

  systems:
    type: class
    glob:
      - "/Users/omarsalem/CLionProjects/Scavenger_Hunt/systems/*.cpp"

  data:
    type: class
    glob:
      - "/Users/omarsalem/CLionProjects/Scavenger_Hunt/data/*.cpp"

  ui:
    type: class
    glob:
      - "/Users/omarsalem/CLionProjects/Scavenger_Hunt/ui/*.cpp"

  main:
    type: class
    glob:
      - "/Users/omarsalem/CLionProjects/Scavenger_Hunt/main.cpp"